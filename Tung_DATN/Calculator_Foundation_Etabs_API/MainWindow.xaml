<Window x:Class="Calculator_Foundation_Etabs_API.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculator_Foundation_Etabs_API"
        mc:Ignorable="d"
        Title="ETABS API Hello World" Height="600" Width="1000" WindowStartupLocation="CenterScreen">
    

    <Grid Background="#F1F5F9">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" >
            <TextBlock Text="ETABS API Connection Test" FontSize="32" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <Border Background="White" CornerRadius="12" Padding="40" Width="500">
                <StackPanel>
                    <TextBlock Text="Status:" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBlock x:Name="StatusText" Text="Waiting for connection check..." FontSize="18" Foreground="#334155" Margin="0,0,0,20"/>
                    
                    <Button Content="Check ETABS Connection" Click="BtnCheckConnection_Click" HorizontalAlignment="Stretch"/>
                </StackPanel>
             
            </Border>

            <TextBlock Text="Make sure ETABS is running with an open model." FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
